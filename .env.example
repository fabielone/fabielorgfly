# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres URI (Project Settings → Database) for local migrations: npm run db:migrate
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# CV uploads use Storage bucket `application_cvs` (created by latest Supabase migration).
#
# If profile/settings save fails in production, apply migrations or paste
# `supabase/manual_sync_profiles_for_app.sql` into Supabase → SQL Editor.

# Mercado Pago (server-side only; set as Fly secrets)
# Webhook: POST /api/webhooks/mercadopago — needs both; token used to load payment/order/preapproval after verify.
MERCADOPAGO_ACCESS_TOKEN=
# Set true with "Credenciales de prueba" token; use Mercado Pago *test buyer* accounts at checkout (Tu aplicación → Cuentas de prueba).
MERCADOPAGO_SANDBOX=false
# If sandbox returns "both payer and collector must be real or test users" on *Pay*, set to the test comprador email from Cuentas de prueba (not your real Gmail).
# MERCADOPAGO_SANDBOX_PAYER_EMAIL=test_user_123456@testuser.com
MERCADOPAGO_WEBHOOK_SECRET=

# Production: redirect *.fly.dev to your public site (301/308). Optional; defaults to https://fabiel.org
# CANONICAL_ORIGIN=https://fabiel.org

# Public site URL (Mercado Pago back_url, links). Recommended in production: https://fabiel.org
# PUBLIC_SITE_URL=https://fabiel.org

# Optional: Plausible analytics domain (e.g. fabiel.org). Loads only after "Accept all" in the cookie banner.
# VITE_PLAUSIBLE_DOMAIN=fabiel.org
